/** 首页样式 — iOS 浅色起卦 */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.page-paper {
  min-height: 100vh;
  background: #f5f5f7;
  color: #1d1d1f;
  padding-bottom: 48rpx;
}

.hero {
  width: 100%;
  padding: 64rpx 40rpx 0;
  text-align: center;
  box-sizing: border-box;
}

.hero-label {
  display: block;
  margin-bottom: 12rpx;
  color: #86868b;
  font-size: 23rpx;
  letter-spacing: 0;
}

.hero-title {
  display: block;
  color: #1d1d1f;
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.07;
  letter-spacing: 0;
}

.hero-subtitle {
  display: block;
  max-width: 560rpx;
  margin: 16rpx auto 0;
  color: #424245;
  font-size: 26rpx;
  line-height: 1.47;
}

.input-section {
  width: 100%;
  padding: 28rpx 40rpx 0;
  box-sizing: border-box;
}


.topic-card {
  position: relative;
  display: flex;
  align-items: stretch;
  min-height: 132rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.76));
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.045);
  box-sizing: border-box;
  overflow: hidden;
}

.topic-card::after {
  content: '';
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  width: 128rpx;
  height: 52rpx;
  background: radial-gradient(ellipse, rgba(176, 132, 61, 0.06), transparent 70%);
  pointer-events: none;
}

.topic-accent {
  flex-shrink: 0;
  width: 6rpx;
  margin: 4rpx 22rpx 4rpx 0;
  background: linear-gradient(180deg, rgba(176, 132, 61, 0.82), rgba(134, 134, 139, 0.18));
  border-radius: 999rpx;
  opacity: 0.86;
}

.topic-content {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.topic-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.topic-label {
  display: inline-block;
  color: #1d1d1f;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.2;
}

.topic-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.topic-pill {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  color: #86868b;
  font-size: 20rpx;
  line-height: 1.2;
  background: rgba(245, 245, 247, 0.9);
  border: 1rpx solid rgba(0, 0, 0, 0.045);
  border-radius: 999rpx;
}

.history-entry {
  min-width: 64rpx;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a87935;
  background: rgba(168, 121, 53, 0.1);
  border: 1rpx solid rgba(168, 121, 53, 0.14);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
}

.search-input {
  display: flex;
  align-items: center;
  height: 92rpx;
  padding: 0 34rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 9999rpx;
}

.search-icon {
  margin-right: 16rpx;
  color: #86868b;
  font-size: 30rpx;
}

.input-field {
  width: 100%;
  height: 50rpx;
  color: #1d1d1f;
  font-size: 30rpx;
  line-height: 50rpx;
  background: transparent;
}

.topic-chips {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin: 26rpx 0 0;
}

.role-chips {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.topic-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 58rpx;
  padding: 0 10rpx;
  color: #515154;
  font-size: 21rpx;
  line-height: 1;
  text-align: center;
  background: rgba(238, 238, 242, 0.86);
  border-radius: 999rpx;
  box-sizing: border-box;
}

.topic-chip.active {
  color: #ffffff;
  font-weight: 600;
  background: #1d1d1f;
}

.role-chip {
  height: 58rpx;
  color: #7a5628;
  background: rgba(154, 107, 47, 0.1);
}

.role-chip.active {
  color: #ffffff;
  background: rgba(154, 107, 47, 0.92);
}

.auto-note {
  display: block;
  margin-top: 12rpx;
  color: #86868b;
  font-size: 20rpx;
  line-height: 1.35;
}

.record-panel {
  width: calc(100% - 80rpx);
  margin-top: 28rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e0e0e0;
  border-radius: 36rpx;
  box-sizing: border-box;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.record-title {
  color: #1d1d1f;
  font-size: 24rpx;
  font-weight: 500;
}

.record-count {
  color: #86868b;
  font-size: 23rpx;
}

.record-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.record-chip {
  min-width: 188rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 16rpx;
  color: #86868b;
  font-size: 23rpx;
  text-align: center;
  background: #f5f5f7;
  border-radius: 9999rpx;
  box-sizing: border-box;
}

.record-chip.filled {
  color: #1d1d1f;
  background: #ffffff;
  border: 1rpx solid #e0e0e0;
}

.record-chip.moving {
  color: #007aff;
  border-color: #0066cc;
}


.gua-progress {
  width: calc(100% - 80rpx);
  max-height: 0;
  margin-top: 0;
  padding: 14rpx 8rpx 4rpx;
  background: transparent;
  border: none;
  border-radius: 0;
  box-sizing: border-box;
  opacity: 0;
  overflow: hidden;
  transform: translateY(-12rpx);
  transition: opacity 0.38s ease, transform 0.38s ease, max-height 0.38s ease, margin-top 0.38s ease;
}

.gua-progress.visible {
  max-height: 310rpx;
  margin-top: 22rpx;
  opacity: 1;
  transform: translateY(0);
}

.gua-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.gua-title {
  color: #86868b;
  font-size: 24rpx;
  font-weight: 500;
}

.gua-count {
  color: #86868b;
  font-size: 23rpx;
}

.gua-dots {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10rpx;
}

.gua-dot {
  height: 8rpx;
  background: rgba(134, 134, 139, 0.2);
  border-radius: 999rpx;
  transition: background 0.24s ease, transform 0.24s ease;
}

.gua-dot.done {
  background: rgba(29, 29, 31, 0.86);
}

.gua-dot.moving {
  background: rgba(176, 132, 61, 0.9);
}

.gua-summary {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 14rpx;
}

.gua-summary-pill {
  padding: 7rpx 14rpx;
  color: #86868b;
  font-size: 21rpx;
  line-height: 1.2;
  background: rgba(245, 245, 247, 0.82);
  border-radius: 999rpx;
}

.product-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0;
  box-sizing: border-box;
  touch-action: none;
}

.casting-module {
  flex: none;
  justify-content: center;
  width: calc(100% - 48rpx);
  max-width: 704rpx;
  min-height: 520rpx;
  margin-top: 42rpx;
  padding: 24rpx 0;
  border-radius: 32rpx;
  box-sizing: border-box;
}

.product-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.coin-stage {
  position: relative;
  width: 100%;
  min-height: 326rpx;
  margin-top: 6rpx;
}

.coin-tray {
  position: relative;
  width: 620rpx;
  max-width: calc(100vw - 80rpx);
  height: 300rpx;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  box-sizing: border-box;
  transition: transform 0.25s ease;
}

.coin-aura {
  position: absolute;
  left: 54rpx;
  right: 54rpx;
  top: 30rpx;
  bottom: 54rpx;
  background: radial-gradient(ellipse at 50% 50%, rgba(215, 183, 122, 0.1), rgba(215, 183, 122, 0.035) 42%, transparent 72%);
  border-radius: 999rpx;
  opacity: 0.45;
  transform: scale(1);
  transition: transform 0.25s ease, opacity 0.25s ease;
  pointer-events: none;
  animation: coinAuraBreathe 4.6s ease-in-out infinite;
}
.tray-rim {
  display: none;
}

.tray-shadow {
  position: absolute;
  left: 96rpx;
  right: 96rpx;
  bottom: 28rpx;
  height: 26rpx;
  background: radial-gradient(ellipse, rgba(39, 25, 12, 0.12) 0%, rgba(39, 25, 12, 0.04) 42%, transparent 76%);
  transition: transform 0.25s ease, opacity 0.25s ease;
  pointer-events: none;
}
.coin-stack {
  display: block;
}

.coin-stack-image {
  position: relative;
  z-index: 3;
  width: 620rpx;
  height: 362rpx;
  max-width: calc(100vw - 80rpx);
  transition: transform 0.25s ease, filter 0.25s ease;
}

.holding .coin-tray {
  transform: scale(1.012);
}

.holding .coin-aura {
  opacity: 0.72;
  animation: coinAuraHold 0.9s ease-in-out infinite;
}

.holding .coin-stack-image {
  animation: coinStackRattle 0.84s linear infinite !important;
}

@keyframes coinStackRattle {
  0% { transform: translate(0, 0) rotate(0deg) scale(1); }
  8% { transform: translate(-13rpx, -18rpx) rotate(-5deg) scale(1.018); }
  17% { transform: translate(11rpx, 10rpx) rotate(4deg) scale(0.992); }
  27% { transform: translate(18rpx, -13rpx) rotate(-3.2deg) scale(1.012); }
  39% { transform: translate(-10rpx, 15rpx) rotate(5.2deg) scale(0.996); }
  52% { transform: translate(7rpx, -22rpx) rotate(-6deg) scale(1.022); }
  66% { transform: translate(-17rpx, 8rpx) rotate(3.5deg) scale(0.992); }
  81% { transform: translate(14rpx, -9rpx) rotate(5.8deg) scale(1.012); }
  92% { transform: translate(-8rpx, 12rpx) rotate(-2.6deg) scale(1); }
  100% { transform: translate(0, 0) rotate(0deg) scale(1); }
}

.settling .coin-stack-image {
  animation: coinStackSettle 0.52s cubic-bezier(0.16, 1, 0.3, 1) forwards !important;
}

.settling .coin-aura {
  animation: coinAuraSettle 0.52s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes coinAuraBreathe {
  0%, 100% { transform: scale(0.96); opacity: 0.36; }
  50% { transform: scale(1.04); opacity: 0.5; }
}

@keyframes coinAuraHold {
  0%, 100% { transform: scale(1.02); opacity: 0.58; }
  50% { transform: scale(1.12); opacity: 0.76; }
}

@keyframes coinAuraSettle {
  0% { transform: scale(1.14); opacity: 0.72; }
  58% { transform: scale(0.96); opacity: 0.38; }
  100% { transform: scale(1); opacity: 0.44; }
}

@keyframes coinStackSettle {
  0% { transform: translateY(-18rpx) scale(1.03) rotate(-3deg); filter: brightness(1.08); }
  48% { transform: translateY(10rpx) scale(0.99) rotate(2deg); filter: brightness(0.98); }
  72% { transform: translateY(-5rpx) scale(1.01) rotate(-1deg); filter: brightness(1.04); }
  100% { transform: translateY(0) scale(1) rotate(0deg); filter: brightness(1); }
}

.product-shadow {
  width: 300rpx;
  height: 36rpx;
  margin-top: 14rpx;
  background: radial-gradient(ellipse, rgba(40, 29, 14, 0.2) 0%, transparent 72%);
  transition: transform 0.25s ease, opacity 0.25s ease;
}

.holding .tray-shadow {
  transform: scaleX(0.82);
  opacity: 0.42;
}

.cta-hint {
  margin: 0 0 4rpx;
  color: #1d1d1f;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0;
  line-height: 1.35;
  text-align: center;
}

.cta-hint.active {
  color: rgba(154, 107, 47, 0.86);
  font-weight: 700;
}


.quick-row {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  margin-top: 14rpx;
  padding-right: 72rpx;
  box-sizing: border-box;
}

.module-support {
  width: calc(100% - 72rpx);
  margin-top: 16rpx;
  padding-top: 0;
  box-sizing: border-box;
}

.quick-complete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  min-width: 132rpx;
  height: 56rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
  color: #424245;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  background: rgba(236, 236, 240, 0.92);
  border: 1rpx solid rgba(0, 0, 0, 0.035);
  border-radius: 999rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.025);
  box-sizing: border-box;
}

.quick-complete-hover {
  background: rgba(226, 226, 231, 0.96);
}

.ritual-hint {
  width: calc(100% - 80rpx);
  margin-top: 28rpx;
  color: rgba(154, 107, 47, 0.72);
  font-size: 23rpx;
  font-weight: 500;
  line-height: 1.45;
  text-align: center;
}
.footer-legal {
  width: 100%;
  margin-top: auto;
  padding: 16rpx 30rpx 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.legal-text {
  color: rgba(134, 134, 139, 0.72);
  font-size: 20rpx;
  line-height: 1.45;
}
