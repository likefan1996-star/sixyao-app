/** 首页样式 — v0.1 经典卡通风格 */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-dark {
  background: #1d1d1f;
}

.hero {
  width: 100%;
  padding: 120rpx 40rpx 0;
  text-align: center;
}

.hero-label {
  font-size: 28rpx;
  color: #86868b;
  font-weight: 400;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 72rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: -2rpx;
  line-height: 1.1;
  display: block;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 32rpx;
  color: #86868b;
  font-weight: 400;
  letter-spacing: 2rpx;
  line-height: 1.2;
  display: block;
  margin-bottom: 10rpx;
}

.input-section {
  width: 100%;
  padding: 90rpx 40rpx 0;
  box-sizing: border-box;
}

.search-input {
  display: flex;
  align-items: center;
  background: #2a2a3e;
  border-radius: 9999rpx;
  padding: 12rpx 28rpx;
  height: 88rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.search-icon {
  font-size: 32rpx;
  color: #86868b;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  color: #ffffff;
  background: transparent;
}

.product-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 30rpx 40rpx;
}

.product-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 30rpx;
}

.coin-group {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  transition: transform 0.3s;
}

.coin {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.coin-1 {
  background: radial-gradient(circle at 35% 30%, #ffd700, #f0a500 45%, #cc8800);
  box-shadow: 0 8rpx 28rpx rgba(255, 215, 0, 0.35), 0 4rpx 12rpx rgba(0,0,0,0.15), inset 0 -4rpx 8rpx rgba(0,0,0,0.1), inset 0 4rpx 8rpx rgba(255,255,200,0.3);
  border: 3rpx solid #e6a800;
}
.coin-2 {
  background: radial-gradient(circle at 35% 30%, #ffe4b5, #d4a562 45%, #b8860b);
  box-shadow: 0 8rpx 28rpx rgba(212, 165, 98, 0.35), 0 4rpx 12rpx rgba(0,0,0,0.15), inset 0 -4rpx 8rpx rgba(0,0,0,0.1), inset 0 4rpx 8rpx rgba(255,255,200,0.3);
  border: 3rpx solid #c8962e;
}
.coin-3 {
  background: radial-gradient(circle at 35% 30%, #f0e6c8, #c4a265 45%, #a0762c);
  box-shadow: 0 8rpx 28rpx rgba(160, 118, 44, 0.35), 0 4rpx 12rpx rgba(0,0,0,0.15), inset 0 -4rpx 8rpx rgba(0,0,0,0.1), inset 0 4rpx 8rpx rgba(255,255,200,0.3);
  border: 3rpx solid #b8922e;
}

.coin-hole {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  background: #1d1d1f;
  border-radius: 4rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  z-index: 2;
}

.coin-mark {
  font-size: 36rpx;
  color: #6b4f15;
  font-weight: 700;
  z-index: 3;
  margin-top: -4rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  text-shadow: 0 1rpx 2rpx rgba(255,255,200,0.3);
}
.coin-1 .coin-mark { color: #7a5c10; }
.coin-2 .coin-mark { color: #6b4f15; }
.coin-3 .coin-mark { color: #5c4210; }

.coin::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 20rpx;
  width: 44rpx;
  height: 18rpx;
  background: radial-gradient(ellipse, rgba(255,255,240,0.5), transparent);
  border-radius: 50%;
  z-index: 4;
}
.coin::after {
  content: '';
  position: absolute;
  top: 28rpx;
  right: 26rpx;
  width: 10rpx;
  height: 10rpx;
  background: rgba(255,255,240,0.3);
  border-radius: 50%;
  z-index: 4;
}

.coin-sparkle {
  position: absolute;
  font-size: 24rpx;
  z-index: 5;
  animation: sparkle 1.5s ease-in-out infinite;
}
.coin-1 .coin-sparkle { top: -12rpx; right: -8rpx; }
.coin-3 .coin-sparkle { bottom: -8rpx; left: -4rpx; animation-delay: 0.5s; }

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.2) rotate(20deg); }
}

.coin-1, .coin-2, .coin-3 { animation: coinFloat 3s ease-in-out infinite; }
.coin-2 { animation-delay: 0.5s; }
.coin-3 { animation-delay: 1s; }

@keyframes coinFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.shaking .coin { animation: coinCartoonShake 0.25s ease-in-out infinite !important; }
.shaking .coin-1 { animation-delay: 0s !important; }
.shaking .coin-2 { animation-delay: 0.1s !important; }
.shaking .coin-3 { animation-delay: 0.2s !important; }

@keyframes coinCartoonShake {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  20% { transform: translateY(-32rpx) rotate(-20deg); }
  40% { transform: translateY(-10rpx) rotate(15deg); }
  60% { transform: translateY(-22rpx) rotate(-10deg); }
  80% { transform: translateY(-6rpx) rotate(8deg); }
}

.toss .coin { animation: coinToss 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards !important; }
.toss .coin-1 { animation-delay: 0s !important; }
.toss .coin-2 { animation-delay: 0.12s !important; }
.toss .coin-3 { animation-delay: 0.24s !important; }

@keyframes coinToss {
  0% { transform: translateY(0) scale(1); opacity: 1; }
  25% { transform: translateY(-140rpx) scale(1.1) rotate(-30deg); opacity: 0.8; }
  50% { transform: translateY(-80rpx) scale(0.95) rotate(20deg); opacity: 0.9; }
  75% { transform: translateY(-30rpx) scale(1.05) rotate(-10deg); opacity: 1; }
  100% { transform: translateY(0) scale(1) rotate(0deg); opacity: 1; }
}

.product-shadow {
  width: 280rpx;
  height: 36rpx;
  background: radial-gradient(ellipse, rgba(0,0,0,0.25) 0%, transparent 70%);
  margin-top: 6rpx;
  transition: all 0.3s;
}
.shaking .product-shadow, .toss .product-shadow { width: 200rpx; opacity: 0.4; }

.step-indicator {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

.step-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  transition: all 0.3s;
}
.step-dot.active {
  background: #f0a500;
  box-shadow: 0 0 20rpx rgba(240,165,0,0.5);
  transform: scale(1.3);
}

.cta-hint {
  font-size: 28rpx;
  color: #86868b;
  letter-spacing: 2rpx;
  transition: color 0.3s;
}
.cta-hint.active { color: #ffd700; }

.footer-legal {
  width: 100%;
  text-align: center;
  padding: 30rpx;
}
.legal-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.2);
}
