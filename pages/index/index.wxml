<!-- 首页 — v0.1 经典卡通风格 -->
<view class="page page-dark">
  <view class="hero">
    <text class="hero-label">六爻 · 传统文化</text>
    <text class="hero-title">周易六爻</text>
    <text class="hero-subtitle">摇钱起卦 · 传统排盘</text>
  </view>
  <view class="input-section">
    <view class="search-input">
      <text class="search-icon">⌕</text>
      <input class="input-field" placeholder="写下您想问的事情…" 
             bindinput="onInput" value="{{question}}" maxlength="50" 
             placeholder-style="color:#86868b" />
    </view>
  </view>
  <view class="product-section" bindtap="onThrow">
    <view class="product-tile">
      <view class="coin-group {{animClass}}">
        <view class="coin coin-1">
          <view class="coin-hole"></view>
          <text class="coin-mark">乾</text>
          <text class="coin-sparkle">✦</text>
        </view>
        <view class="coin coin-2">
          <view class="coin-hole"></view>
          <text class="coin-mark">坤</text>
        </view>
        <view class="coin coin-3">
          <view class="coin-hole"></view>
          <text class="coin-mark">道</text>
          <text class="coin-sparkle">✦</text>
        </view>
      </view>
      <view class="product-shadow"></view>
    </view>
    <view class="step-indicator" wx:if="{{throwing}}">
      <view wx:for="{{6}}" wx:key="*this" class="step-dot {{currentStep > index ? 'active' : ''}}"></view>
    </view>
    <text class="cta-hint {{throwing ? 'active' : ''}}">{{throwing ? stepText : '点击铜钱 · 开始摇卦'}}</text>
  </view>
  <view class="footer-legal">
    <text class="legal-text">仅供传统文化学习参考</text>
  </view>
</view>
