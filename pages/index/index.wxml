<view class="page page-paper">
  <view class="hero">
    <text class="hero-title">周易六爻</text>
    <text class="hero-subtitle">传统文化学习用的六爻排盘演示</text>
  </view>

  <view class="input-section">
    <view class="topic-card">
      <view class="topic-accent"></view>
      <view class="topic-content">
        <view class="topic-heading">
          <text class="topic-label">这次想看什么？</text>
          <view class="topic-actions">
            <text class="topic-pill">学习主题</text>
            <view class="history-entry" bindtap="onOpenHistory">历史</view>
          </view>
        </view>
        <input class="input-field"
               placeholder="写下一个想观察的问题"
               bindinput="onInput"
               value="{{question}}"
               maxlength="50"
               aria-label="写下一个想观察的问题"
               placeholder-style="color:#86868b" />
        <view class="topic-chips">
          <view wx:for="{{topicTypes}}" wx:key="key"
                class="topic-chip {{selectedTopic === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="onSelectTopic">{{item.label}}</view>
        </view>
        <view class="role-chips" wx:if="{{selectedTopic === 'relationship'}}">
          <view wx:for="{{relationshipRoles}}" wx:key="key"
                class="topic-chip role-chip {{selectedRole === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="onSelectRole">{{item.label}}</view>
        </view>
        <text class="auto-note">不选也可以，系统会自动识别。</text>
      </view>
    </view>
  </view>

  <view class="gua-progress {{progressVisible ? 'visible' : ''}}">
    <view class="gua-header">
      <text class="gua-title">成卦中</text>
      <text class="gua-count">{{currentStep}} / 6</text>
    </view>
    <view class="gua-dots" aria-label="六爻成卦进度">
      <view wx:for="{{progressDots}}" wx:key="index"
            class="gua-dot {{item.done ? 'done' : ''}} {{item.moving ? 'moving' : ''}}"></view>
    </view>
    <view class="gua-summary" wx:if="{{completedYaoSummary.length}}">
      <text class="gua-summary-pill" wx:for="{{completedYaoSummary}}" wx:key="text">{{item.text}}</text>
    </view>
  </view>

  <view class="ritual-hint">可先静心默念主题，再按住铜钱盏</view>

  <view class="product-section casting-module {{animClass}}">
    <text class="cta-hint {{holding || throwing ? 'active' : ''}}">{{stepText}}</text>
    <view class="product-tile coin-stage">
      <view class="coin-tray"
            aria-label="按住铜钱盏摇卦"
            bindtouchstart="onHoldStart"
            bindtouchend="onHoldEnd"
            bindtouchcancel="onHoldCancel">
        <view class="coin-aura"></view>
        <view class="tray-rim"></view>
        <image class="coin-stack coin-stack-image"
               src="/assets/images/coin-stack.svg"
               mode="aspectFit"
               show-menu-by-longpress="{{false}}" />
        <view class="tray-shadow"></view>
      </view>
    </view>
    <view class="module-support">
      <view class="quick-row">
        <view class="quick-complete"
              hover-class="quick-complete-hover"
              bindtap="onQuickComplete"
              aria-label="一键完成六爻排盘">一键成卦</view>
      </view>
    </view>
  </view>

  <view class="footer-legal">
    <text class="legal-text">内容用于传统文化学习与自我梳理，不作为现实决策依据。</text>
  </view>
</view>
