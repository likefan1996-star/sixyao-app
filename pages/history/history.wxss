page {
  background: #f5f5f7;
  color: #1d1d1f;
}

.history-page {
  min-height: 100vh;
  padding: 72rpx 28rpx 52rpx;
  box-sizing: border-box;
}

.history-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #a87935;
  font-size: 24rpx;
  font-weight: 600;
}

.title {
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  color: #86868b;
  font-size: 25rpx;
  line-height: 1.5;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  position: relative;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(29, 29, 31, 0.08);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.05);
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-right: 104rpx;
}

.record-question {
  color: #1d1d1f;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 700;
}

.record-hexagram {
  color: #6e6e73;
  font-size: 25rpx;
  line-height: 1.45;
}

.record-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(29, 29, 31, 0.07);
}

.record-tier {
  color: #a87935;
  font-size: 24rpx;
  font-weight: 700;
}

.record-time {
  color: #9a9aa0;
  font-size: 23rpx;
}

.delete-record {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  min-width: 72rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #86868b;
  background: rgba(245, 245, 247, 0.92);
  font-size: 23rpx;
  font-weight: 600;
}

.empty-state {
  min-height: 360rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(29, 29, 31, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.04);
}

.empty-title {
  color: #1d1d1f;
  font-size: 31rpx;
  font-weight: 800;
}

.empty-copy {
  color: #86868b;
  font-size: 25rpx;
}
