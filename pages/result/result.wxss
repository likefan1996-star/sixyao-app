/** 结果页样式 — 经典版 Apple Design Language */
.page-parchment {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* ===== 通用卡片 ===== */
.utility-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.card-label {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 400;
  letter-spacing: -0.2rpx;
  display: block;
  margin-bottom: 8rpx;
}

.card-value {
  font-size: 34rpx;
  color: #1d1d1f;
  font-weight: 600;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.card-value-sm {
  font-size: 28rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-hint {
  font-size: 22rpx;
  color: #86868b;
  margin-top: 8rpx;
  display: block;
}

/* ===== 产品卡片（卦象） ===== */
.product-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
}

.product-card-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.product-name {
  font-size: 48rpx;
  color: #1d1d1f;
  font-weight: 600;
  letter-spacing: -1rpx;
  line-height: 1.07;
}

.product-char {
  font-size: 40rpx;
  color: #1d1d1f;
  font-weight: 400;
}

.pill-tag {
  font-size: 20rpx;
  color: #86868b;
  background: #f5f5f7;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  margin-left: auto;
  font-weight: 400;
}

/* 卦辞 */
.guaci-block {
  background: #f5f5f7;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}

.guaci-text {
  font-size: 26rpx;
  color: #1d1d1f;
  font-weight: 400;
  letter-spacing: -0.2rpx;
  line-height: 1.5;
}

/* ===== 卦画渲染 ===== */
.hexagram-render {
  margin-bottom: 20rpx;
}

.yao-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.yao-row:last-child {
  border-bottom: none;
}

.yao-row.moving {
  background: rgba(0,102,204,0.03);
  margin: 0 -12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
}

.yao-tag {
  font-size: 20rpx;
  color: #86868b;
  width: 56rpx;
  flex-shrink: 0;
  text-align: center;
  font-weight: 400;
}

.yao-line-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 36rpx;
}

.yao-line {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 70%;
}

.line-bar {
  display: flex;
  align-items: center;
}

.bar-solid {
  width: 100%;
  height: 10rpx;
  background: #1d1d1f;
  border-radius: 5rpx;
}

.bar-split {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: space-between;
}

.bar-part {
  width: 38%;
  height: 10rpx;
  background: #1d1d1f;
  border-radius: 5rpx;
}

.bar-gap {
  width: 14%;
}

.yao-meta {
  width: 120rpx;
  flex-shrink: 0;
  text-align: right;
}

.yao-stem {
  font-size: 20rpx;
  color: #86868b;
  display: block;
}

.yao-qin {
  font-size: 22rpx;
  color: #1d1d1f;
  font-weight: 500;
  display: block;
  margin-top: 2rpx;
}

.yao-qin.moving {
  color: #0066cc;
}

.meta-bar {
  text-align: center;
  font-size: 22rpx;
  color: #86868b;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* ===== 吉凶徽章 ===== */
.auspicious-pill {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  padding: 10rpx 36rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.level-shunchang { color: #2d7d46; background: rgba(45,125,70,0.1); border: 2rpx solid rgba(45,125,70,0.25); }
.level-pinghuan { color: #b8860b; background: rgba(184,134,11,0.08); border: 2rpx solid rgba(184,134,11,0.18); }
.level-zuzhi { color: #c0392b; background: rgba(192,57,43,0.08); border: 2rpx solid rgba(192,57,43,0.2); }
.level-xiongxian { color: #2c3e50; background: rgba(44,62,80,0.08); border: 2rpx solid rgba(44,62,80,0.2); }

/* ===== 折叠区 ===== */
.detail-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.trigger-icon {
  font-size: 24rpx;
  color: #86868b;
}

.detail-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.detail-content.active {
  max-height: 3000rpx;
}

.analysis-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.analysis-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.analysis-body {
  font-size: 26rpx;
  color: #1d1d1f;
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: -0.2rpx;
}

/* ===== 免责 ===== */
.disclaimer {
  text-align: center;
  font-size: 20rpx;
  color: #c7c7cc;
  padding: 10rpx 0;
}

/* ===== 固定底部栏 ===== */
.sticky-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  justify-content: center;
}

.btn-primary {
  width: 70%;
  height: 100rpx;
  line-height: 100rpx;
  background: #0066cc;
  color: #ffffff;
  border-radius: 9999rpx;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 0;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.97);
}
