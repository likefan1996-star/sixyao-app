/** 结果页样式 — 卦象结构参考 */
.page-paper {
  min-height: 100vh;
  padding: 24rpx 24rpx 168rpx;
  background: #f5f5f7;
  color: #1d1d1f;
  box-sizing: border-box;
}

.question-strip,
.section-card,
.fortune-hero {
  background: #ffffff;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.question-strip {
  padding: 24rpx 28rpx;
  border-radius: 36rpx;
  margin-bottom: 18rpx;
}

.strip-label {
  display: block;
  margin-bottom: 8rpx;
  color: #7a7a7a;
  font-size: 23rpx;
}

.strip-value {
  color: #1d1d1f;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
}

.fortune-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx 28rpx 42rpx;
  border-radius: 36rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.035);
  --tier-color: #0066cc;
  --tier-soft: rgba(0, 102, 204, 0.08);
}

.fortune-accent {
  position: absolute;
  left: 22rpx;
  top: 34rpx;
  bottom: 34rpx;
  width: 5rpx;
  background: linear-gradient(180deg, var(--tier-color), rgba(134, 134, 139, 0.18));
  border-radius: 999rpx;
}

.fortune-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.fortune-kicker {
  display: block;
  color: #7a7a7a;
  font-size: 23rpx;
  letter-spacing: 0;
}

.fortune-brand {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  color: #8a611f;
  font-size: 20rpx;
  line-height: 1.2;
  background: rgba(176, 132, 61, 0.08);
  border-radius: 999rpx;
}

.fortune-main {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 12rpx;
}

.fortune-name {
  color: #1d1d1f;
  font-size: 96rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: -1rpx;
}

.fortune-advice {
  display: block;
  margin-top: 18rpx;
  color: #1d1d1f;
  font-size: 29rpx;
  line-height: 1.55;
}

.reading-guide-compact {
  margin-top: 24rpx;
  padding: 6rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.055);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.055);
}

.scale-track {
  display: flex;
  gap: 6rpx;
  margin-top: 26rpx;
}

.scale-segment {
  position: relative;
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a7a7a;
  font-size: 21rpx;
  background: #f5f5f7;
  border-radius: 9999rpx;
}

.scale-segment.active {
  color: #ffffff;
  background: var(--tier-color);
  font-weight: 600;
}

.segment-marker {
  position: absolute;
  left: 50%;
  bottom: -23rpx;
  width: 0;
  height: 0;
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-bottom: 14rpx solid var(--tier-color);
  transform: translateX(-9rpx);
}

.range-text {
  display: block;
  margin-top: 8rpx;
  color: #7a7a7a;
  font-size: 22rpx;
}

.fortune-signature {
  display: block;
  margin-top: 18rpx;
  color: #86868b;
  font-size: 21rpx;
  line-height: 1.35;
  text-align: right;
}

.level-shangshang { --tier-color: #0066cc; --tier-soft: rgba(0, 102, 204, 0.08); }
.level-daji { --tier-color: #147ad6; --tier-soft: rgba(20, 122, 214, 0.08); }
.level-zhongji { --tier-color: #2f8f6b; --tier-soft: rgba(47, 143, 107, 0.1); }
.level-xiaoji { --tier-color: #b0843d; --tier-soft: rgba(176, 132, 61, 0.1); }
.level-zhongping { --tier-color: #86868b; --tier-soft: rgba(134, 134, 139, 0.1); }
.level-xiaxia { --tier-color: #9a6b2f; --tier-soft: rgba(154, 107, 47, 0.1); }
.level-xiong { --tier-color: #8a3d2f; --tier-soft: rgba(138, 61, 47, 0.1); }
.level-error { --tier-color: #86868b; --tier-soft: rgba(134, 134, 139, 0.1); }

.level-shangshang .fortune-name,
.level-daji .fortune-name,
.level-zhongji .fortune-name { color: var(--tier-color); }
.level-xiaoji .fortune-name,
.level-zhongping .fortune-name,
.level-xiaxia .fortune-name,
.level-xiong .fortune-name,
.level-error .fortune-name { color: #1d1d1f; }

.term-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.term-item {
  min-height: 74rpx;
  padding: 15rpx 16rpx;
  background: #f7f7f9;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.term-name {
  display: inline;
  color: #8a611f;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
}

.term-meaning {
  display: inline;
  margin-left: 8rpx;
  color: #515154;
  font-size: 22rpx;
  line-height: 1.35;
}

.deep-reading-card {
  overflow: hidden;
}

.deep-pill {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  color: #8a611f;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.2;
  background: rgba(176, 132, 61, 0.08);
  border-radius: 999rpx;
}

.deep-summary {
  display: block;
  padding: 24rpx 24rpx 24rpx 28rpx;
  color: #1d1d1f;
  font-size: 26rpx;
  line-height: 1.68;
  background: linear-gradient(135deg, rgba(176, 132, 61, 0.08), rgba(247, 247, 249, 0.78));
  border-left: 5rpx solid #b0843d;
  border-radius: 24rpx;
}

.deep-list {
  margin-top: 18rpx;
}

.deep-item {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  gap: 20rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.055);
}

.deep-item:first-child {
  padding-top: 0;
  border-top: none;
}

.deep-label {
  color: #8a611f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.55;
}

.deep-body {
  color: #424245;
  font-size: 25rpx;
  line-height: 1.65;
}

.deep-footer {
  display: block;
  margin-top: 18rpx;
  padding-top: 18rpx;
  color: #86868b;
  font-size: 21rpx;
  line-height: 1.45;
  border-top: 1rpx solid rgba(0, 0, 0, 0.055);
}

.section-card {
  padding: 28rpx;
  border-radius: 36rpx;
  margin-bottom: 18rpx;
}

.guide-row {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-row.compact {
  padding: 14rpx 0;
  border-bottom-color: rgba(0, 0, 0, 0.045);
}

.guide-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.guide-label {
  width: 132rpx;
  flex-shrink: 0;
  color: #8a611f;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.55;
}

.guide-body {
  flex: 1;
  min-width: 0;
  color: #1d1d1f;
  font-size: 27rpx;
  line-height: 1.62;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #1d1d1f;
  font-size: 30rpx;
  font-weight: 700;
}

.section-note {
  color: #7a7a7a;
  font-size: 23rpx;
}

.pill-tag {
  padding: 6rpx 18rpx;
  color: #8a611f;
  font-size: 22rpx;
  background: #f5f5f7;
  border-radius: 999rpx;
}

.hex-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.hex-name {
  color: #1d1d1f;
  font-size: 56rpx;
  font-weight: 600;
}

.hex-char {
  color: #333333;
  font-size: 38rpx;
}

.guaci-text,
.change-name {
  color: #1d1d1f;
  font-size: 27rpx;
  line-height: 1.6;
}

.source-note {
  display: block;
  margin-top: 14rpx;
  color: #7a7a7a;
  font-size: 22rpx;
  line-height: 1.4;
  text-align: right;
}

.hexagram-render {
  margin-top: 4rpx;
}

.plate-card {
  background: #fbfbfd;
}

.yao-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 13rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.yao-row:last-child {
  border-bottom: none;
}

.yao-row.moving {
  margin: 0 -12rpx;
  padding: 13rpx 12rpx;
  background: rgba(176, 132, 61, 0.08);
  border-radius: 12rpx;
}

.yao-tag {
  width: 58rpx;
  flex-shrink: 0;
  color: #7a7a7a;
  font-size: 21rpx;
  text-align: center;
}

.yao-line-container {
  flex: 1;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.yao-line {
  width: 74%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.line-bar {
  display: flex;
  align-items: center;
}

.bar-solid {
  width: 100%;
  height: 10rpx;
  background: #1d1d1f;
  border-radius: 5rpx;
}

.bar-split {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bar-part {
  width: 38%;
  height: 10rpx;
  background: #1d1d1f;
  border-radius: 5rpx;
}

.bar-gap {
  width: 14%;
}

.yao-meta {
  width: 124rpx;
  flex-shrink: 0;
  text-align: right;
}

.yao-stem {
  display: block;
  color: #7a7a7a;
  font-size: 21rpx;
}

.yao-qin {
  display: block;
  margin-top: 2rpx;
  color: #1d1d1f;
  font-size: 23rpx;
  font-weight: 600;
}

.yao-qin.moving {
  color: #8a611f;
}

.analysis-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.analysis-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.analysis-title {
  display: block;
  margin-bottom: 8rpx;
  color: #8a611f;
  font-size: 26rpx;
  font-weight: 700;
}

.analysis-body {
  display: block;
  color: #1d1d1f;
  font-size: 26rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.source-card {
  position: relative;
  overflow: hidden;
  padding-left: 36rpx;
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(29, 29, 31, 0.075);
  box-shadow: none;
}

.source-accent {
  position: absolute;
  left: 22rpx;
  top: 30rpx;
  bottom: 30rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(176, 132, 61, 0.72), rgba(134, 134, 139, 0.16));
}

.source-header {
  margin-bottom: 12rpx;
}

.source-copy {
  display: block;
  color: #515154;
  font-size: 23rpx;
  line-height: 1.58;
}

.source-copy.muted {
  margin-top: 8rpx;
  color: #86868b;
}

.disclaimer {
  padding: 10rpx 0 22rpx;
  color: #7a7a7a;
  font-size: 21rpx;
  text-align: center;
}

.sticky-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(245, 245, 247, 0.86);
  border-top: 1rpx solid #e0e0e0;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.btn-primary {
  display: block;
  width: 360rpx;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0 auto;
  padding: 0;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  background: #1d1d1f;
  border: none;
  border-radius: 999rpx;
}

.btn-primary::after {
  border: none;
}
