/** 结果页样式 — 多维分析报告 v3.0 **/
.page {
  padding-bottom: 100rpx;
}

.result-header {
  text-align: center;
  padding: 120rpx 60rpx 40rpx;
}

.result-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 72rpx;
  color: var(--text-main);
  letter-spacing: 4rpx;
  line-height: 1.2;
  display: block;
  margin-bottom: 30rpx;
}

.result-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: var(--accent-bronze);
  color: #FFFFFF;
  border-radius: 50px;
  font-size: 24rpx;
  font-weight: 500;
  opacity: 0.9;
}

/* ===== 总评区 ===== */
.verdict-section {
  text-align: center;
  padding: 0;
  overflow: hidden;
}

.verdict-banner {
  padding: 40rpx;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  transition: background-color 0.5s;
}

.verdict-text {
  display: block;
}

.verdict-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 24rpx 40rpx 0;
  line-height: 1.6;
}

.verdict-meta {
  display: block;
  font-size: 24rpx;
  color: var(--accent-bronze);
  padding: 10rpx 40rpx 30rpx;
  opacity: 0.8;
}

/* ===== 三维度区 ===== */
.dims-section {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 32rpx;
  margin: 8rpx 0;
}

.dim-card {
  flex: 1;
  min-width: 200rpx;
  background: var(--card-bg);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-subtle);
  padding: 24rpx;
  opacity: 0;
  transform: translateY(20rpx);
  animation: dimFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes dimFadeIn {
  to { opacity: 1; transform: translateY(0); }
}

.dim-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dim-icon {
  font-size: 32rpx;
  opacity: 0.5;
}

.dim-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.dim-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.dim-detail {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  opacity: 0.7;
}

/* ===== 卦象可视化区 ===== */
.gua-visual-container {
  background: var(--card-bg);
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  margin: 32rpx;
}

.gua-wrapper {
  display: flex;
  flex-direction: column-reverse;
  gap: 30rpx;
  width: 500rpx;
}

.yao-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  opacity: 0;
  transform: translateY(20rpx);
  animation: yaoGrow 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes yaoGrow {
  to { opacity: 1; transform: translateY(0); }
}

.yao-line {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  width: 240rpx;
}

.line-segment {
  height: 16rpx;
  background: var(--text-main);
  border-radius: 8rpx;
}

.yao-line.yang .line-segment { width: 160rpx; }
.yao-line.yin .line-segment { width: 60rpx; }

.yao-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.yao-pos { width: 50rpx; text-align: right; }
.yao-status { width: 70rpx; text-align: center; }
.yao-status.changed { color: var(--accent-bronze); font-weight: 600; }
.yao-liuqin { width: 80rpx; text-align: left; color: var(--accent-stone); }

/* ===== 分析区 ===== */
.analysis-section {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.analysis-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 36rpx;
  color: var(--text-main);
}

.card-content {
  font-size: 30rpx;
  color: #4A4A4E;
  line-height: 1.8;
}

.quote-text {
  display: block;
  font-family: "STSong", "SimSun", serif;
  font-size: 32rpx;
  color: var(--text-main);
  text-align: center;
  margin-bottom: 16rpx;
  font-style: italic;
}

.quote-source {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 详情展开区 */
.detail-section {
  margin-top: 0;
}

.detail-trigger {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: var(--accent-bronze);
  background: rgba(179, 124, 92, 0.05);
  border-radius: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  transition: var(--transition-smooth);
}

.detail-trigger:active { opacity: 0.7; }

.detail-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s cubic-bezier(0, 1, 0, 1);
}

.detail-content.active {
  max-height: 2000rpx;
  transition: max-height 0.5s cubic-bezier(1, 0, 1, 0);
}

.detail-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.detail-title {
  font-size: 32rpx;
  color: var(--text-main);
  border-left: 8rpx solid var(--accent-bronze);
  padding-left: 20rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.detail-bullet {
  color: var(--accent-bronze);
  opacity: 0.6;
}

.detail-text {
  flex: 1;
}

.footer-actions {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 40rpx 60rpx 80rpx;
}
