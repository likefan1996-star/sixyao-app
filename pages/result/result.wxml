<!-- 结果页 — 多维分析报告 v3.0 -->
<view class="page">
  
  <view class="result-header">
    <text class="result-label">推演结果</text>
    <text class="result-title title-serif">{{guaName}}</text>
    <view class="result-badge" wx:if="{{guaPalace}}">{{guaPalace}}</view>
  </view>

  <!-- 总评区（替代原来的同步率百分条） -->
  <view class="verdict-section card">
    <view class="verdict-banner" style="background-color: {{verdictColor}}">
      <text class="verdict-text">{{verdictText}}</text>
    </view>
    <text class="verdict-desc">{{verdictDesc}}</text>
    <text class="verdict-meta" wx:if="{{yongshen}}">用神：{{yongshen}}</text>
  </view>

  <!-- 三维度分析 -->
  <view class="dims-section" wx:if="{{dimensions.length > 0}}">
    <view class="dim-card dim-{{index}}" wx:for="{{dimensions}}" wx:key="index" style="animation-delay: {{index * 0.15}}s">
      <view class="dim-header">
        <text class="dim-icon">
          <text wx:if="{{index === 0}}">⟳</text>
          <text wx:if="{{index === 1}}">⊙</text>
          <text wx:if="{{index === 2}}">⇄</text>
        </text>
        <text class="dim-label">{{item.label}}</text>
      </view>
      <text class="dim-value">{{item.value}}</text>
      <text class="dim-detail">{{item.detail}}</text>
    </view>
  </view>

  <!-- 卦象可视化区 -->
  <view class="gua-visual-container card">
    <view class="gua-wrapper">
      <block wx:for="{{yaoList}}" wx:key="index">
        <view class="yao-row {{item.animClass}}" style="animation-delay: {{index * 0.15}}s">
          <view class="yao-line {{item.type}}">
            <view class="line-segment"></view>
            <view class="line-segment" wx:if="{{item.type !== 'yang'}}"></view>
          </view>
          <view class="yao-info">
            <text class="yao-pos">{{item.index}}爻</text>
            <text class="yao-status {{item.isChanged ? 'changed' : ''}}">{{item.status}}</text>
            <text class="yao-liuqin">{{item.liuqin}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 详细分析区 -->
  <view class="analysis-section">
    <view class="analysis-card card">
      <view class="card-header">
        <text class="card-title title-serif">古籍原文</text>
      </view>
      <view class="card-content">
        <text class="quote-text">“{{quoteText}}”</text>
        <text class="quote-source">— 《周易》</text>
      </view>
    </view>

    <view class="detail-section">
      <view class="detail-trigger" bindtap="toggleDetail">
        <text>{{showDetail ? '收起评分明细' : '展开评分明细'}}</text>
        <text class="trigger-icon">{{showDetail ? '▲' : '▼'}}</text>
      </view>

      <view class="detail-content {{showDetail ? 'active' : ''}}">
        <view class="detail-card card">
          <text class="detail-title title-serif">评分明细</text>
          <view class="detail-list">
            <view class="detail-item" wx:for="{{detailItems}}" wx:key="index">
              <text class="detail-bullet">·</text>
              <text class="detail-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer-actions">
      <button class="btn-primary" bindtap="goBack">重新推演</button>
    </view>
  </view>
</view>
