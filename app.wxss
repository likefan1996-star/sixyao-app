/** 全局样式 - 新中式极简主义 v1.0 **/
page {
  --bg-color: #FBFBFB;
  --card-bg: #FFFFFF;
  --text-main: #2C2C2E;
  --text-secondary: #8E8E93;
  --accent-bronze: #B37C5C;
  --accent-stone: #8E9775;
  --border-radius-lg: 20px;
  --border-radius-sm: 12px;
  --shadow-subtle: 0 4px 20px rgba(0,0,0,0.05);
  --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", STHeiti, "Microsoft YaHei", Tahoma, Arial, Verdana, sans-serif;
  line-height: 1.6;
}

/* 基础组件样式 */
.card {
  background: var(--card-bg);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-subtle);
  padding: 24px;
  margin: 16px;
  transition: var(--transition-smooth);
}

.card-sm {
  border-radius: var(--border-radius-sm);
  padding: 16px;
  margin: 8px 16px;
}

.title-serif {
  font-family: "STSong", "SimSun", serif;
  font-weight: 600;
  color: var(--text-main);
}

.text-secondary {
  color: var(--text-secondary);
  font-size: 14px;
}

.btn-primary {
  background-color: var(--text-main);
  color: #FFFFFF;
  border-radius: 50px;
  padding: 12px 32px;
  font-size: 16px;
  font-weight: 500;
  transition: var(--transition-smooth);
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 抛币动画基础类 */
.coin-container {
  perspective: 1000px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.coin {
  width: 80px;
  height: 80px;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
